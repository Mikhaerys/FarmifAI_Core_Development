# API key de OpenRouter (obligatoria)
OPENROUTER_API_KEY=sk-or-v1-...

# Modelo a usar (opcional, por defecto deepseek/deepseek-v4-flash)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Base URL de la API (opcional, por defecto https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
